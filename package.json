{
	"name": "ez-chars",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"test": "vitest run",
		"test:e2e": "playwright test --project=chromium",
		"test:e2e:all": "playwright test",
		"test:perf": "PLAYWRIGHT_PERF=1 playwright test tests/performance.perf.spec.ts --project=chromium",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"mcp:svelte": "svelte-mcp",
		"format": "prettier --write . && prettier --write \"src/**/*.{js,ts}\" --plugin prettier-plugin-tailwindcss",
		"lint": "prettier --check . && prettier --check \"src/**/*.{js,ts}\" --plugin prettier-plugin-tailwindcss && eslint .",
		"deploy": "vite build && touch build/.nojekyll && npx gh-pages -d build -t && echo \"View deployed site: https://kmfarley11.github.io/ez-chars/\" && echo \"Monitor deploy branch/status: https://github.com/kmfarley11/ez-chars/tree/gh-pages\""
	},
	"devDependencies": {
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@fission-ai/openspec": "1.6.0",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.0",
		"@sveltejs/mcp": "^0.1.24",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/forms": "^0.5.9",
		"@tailwindcss/typography": "^0.5.15",
		"@tailwindcss/vite": "^4.0.0",
		"@types/connect": "^3.4.38",
		"@types/node": "^25.3.2",
		"@typescript-eslint/parser": "^8.56.1",
		"@vitest/coverage-v8": "^4.1.6",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"gh-pages": "^6.3.0",
		"globals": "^16.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"typescript": "^5.0.0",
		"vite": "^6.2.5",
		"vitest": "^4.1.6",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"immutable-json-patch": "^6.0.2",
		"tailwind-merge": "^3.3.0"
	},
	"overrides": {
		"cookie": "^1.1.1"
	}
}
